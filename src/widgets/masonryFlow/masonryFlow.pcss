.masonryFlow {
    width: 100%;
    margin-inline: auto;

    &__masonry {
        max-width: 72rem;
        margin-inline: auto;
    }

    &__figure {
        margin: 0;
        border-radius: 4rem;
        overflow: hidden;
        box-shadow: 0 0.6rem 2rem rgb(15 23 42 / 0.09);
        background: var(--colorSweetGrey30, #f4f4f5);
    }
}
